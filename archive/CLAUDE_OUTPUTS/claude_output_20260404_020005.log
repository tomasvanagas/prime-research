import math

def li(x):
    if x <= 0: return float('-inf')
    if abs(x - 1) < 1e-15: return float('-inf')
    lnx = math.log(x)
    EULER_GAMMA = 0.5772156649015328606065120900824024
    result = EULER_GAMMA + math.log(abs(lnx))
