The heuristic fails at N=10 for all functions. Let me try a refined approach with more trials and larger gate budgets specifically for N=10.
  [Bash] python3 -c "
import numpy as np
from scipy.optimize import linprog
import time

def sieve_primes(limit):
    if limit < 2: return set()
    is_p = [True] * (limit + 1)
    is_p[0] = is_p[1] = False
    for i in range(2, int(limit**0.5) + 1):
        if is_p[i]:
            for j in range(i*i, limit + 1, i):
                is_p[j] = False
    return set(i for i in range(limit + 1) if is_p[i])

N = 10
primes = sieve_primes(2**N - 1)
X = np.zeros((2**N, N), dtype=np.float64)
for i in range(2**N):
    for b in range(N):
        X[i, b] = (i >> b) & 1

is_prime_tt = np.array([1 if x in primes else 0 for x in range(2**N)], dtype=np.int8)
pi_count = 0
pi_mod2_tt = np.zeros(2**N, dtype=np.int8)
for x in range(2**N):
    if x in primes: pi_count += 1
    pi_mod2_tt[x] = pi_count % 2

def find_ltf(features, target):
    n_s, n_f = features.shape
    labels = 2 * target.astype(np.float64) - 1
    c = np.zeros(n_f + 1)
    c[-1] = -1
    A_ub = np.zeros((n_s + 2*n_f, n_f + 1))
    b_ub = np.zeros(n_s + 2*n_f)
    for i in range(n_s):
        A_ub[i, :n_f] = -labels[i] * features[i]
        A_ub[i, -1] = 1
    for j in range(n_f):
        A_ub[n_s + 2*j, j] = 1; b_ub[n_s + 2*j] = 1
        A_ub[n_s + 2*j+1, j] = -1; b_ub[n_s + 2*j+1] = 1
    res = linprog(c, A_ub=A_ub, b_ub=b_ub, method='highs')
    if res.success:
        w = res.x[:n_f]
        preds = (features @ w > 0).astype(np.int8)
        return np.mean(preds == target) == 1.0, np.mean(preds == target)
    return False, 0.5

# Depth 2: try large k with many random trials
print('N=10 depth-2 exhaustive search (k=256,512,1024)')
for k in [256, 512, 1024]:
    best = 0.0
    t0 = time.time()
    for trial in range(100):
        rng = np.random.RandomState(trial * 7 + k)
        W = rng.randn(N, k)
        b = rng.randn(k) * 0.5
        feats = (X @ W + b > 0).astype(np.float64)
        exact, acc = find_ltf(feats, is_prime_tt)
        if acc > best: best = acc
        if exact:
            print(f'  is_prime: EXACT at k={k}, trial={trial}!')
            break
    else:
        print(f'  is_prime: k={k}, best_acc={best:.4f} ({time.time()-t0:.1f}s)')
    
    if k <= 512:  # skip large k for pi_mod2 to save time
        best = 0.0
        for trial in range(100):
            rng = np.random.RandomState(trial * 13 + k)
            W = rng.randn(N, k)
            b = rng.randn(k) * 0.5
            feats = (X @ W + b > 0).astype(np.float64)
            exact, acc = find_ltf(feats, pi_mod2_tt)
            if acc > best: best = acc
            if exact:
                print(f'  pi_mod2: EXACT at k={k}, trial={trial}!')
                break
        else:
            print(f'  pi_mod2: k={k}, best_acc={best:.4f} ({time.time()-t0:.1f}s)')
