from mpmath import mp, mpf, log, li, fabs
import sympy
from sympy import prime as sympy_prime, isprime, nextprime, prevprime

mp.dps = 30

def R_inv(n):
    n = mpf(n)
    x = n * log(n)
    for _ in range(50):
        result = mpf(0)
        for k in range(1, 50):
            mu_k = int(sympy.mobius(k))
            if mu_k == 0: continue
            xk = x ** (mpf(1)/k)
            if xk < 1.01: break
            result += mpf(mu_k)/k * li(xk)
        dx = (result - n) * log(x)
        x -= dx
        if fabs(dx) < mpf(10)**(-20): break
    return float(x)

def R_func(x):
    x = mpf(x)
    result = mpf(0)
    for k in range(1, 50):
        mu_k = int(sympy.mobius(k))
        if mu_k == 0: continue
        xk = x ** (mpf(1)/k)
        if xk < 1.01: break
        result += mpf(mu_k)/k * li(xk)
    return float(result)

# Ultimate formula test
cc = cw = uc = 0
for n in range(10, 501):
    actual = sympy_prime(n)
    r_inv = R_inv(n)
    candidate = round(r_inv)
    if candidate >= 2 and isprime(candidate):
        r_candidate = R_func(candidate)
        if abs(r_candidate - n) < 0.5:
            if candidate == actual: cc += 1
            else: cw += 1
        else: uc += 1
    else: uc += 1

total = 491
print(f'Certified correct: {cc}/{total} = {cc/total*100:.1f}%')
print(f'Certified WRONG:   {cw}/{total} = {cw/total*100:.1f}%')
print(f'Uncertified:       {uc}/{total} = {uc/total*100:.1f}%')
if cc + cw > 0:
    print(f'Precision: {cc/(cc+cw)*100:.1f}%')
    print(f'Coverage: {(cc+cw)/total*100:.1f}%')
" 2>&1
    Certified correct: 24/491 = 4.9%
    Certified WRONG:   41/491 = 8.4%
    Uncertified:       426/491 = 86.8%
    Precision: 36.9%
    Coverage: 13.2%
The self-certification approach fails — only 36.9% precision when it certifies. R(p) ≈ n is NOT a reliable indicator that p = p(n).

