    {"parentUuid":"f2a765fb-9709-45d4-a4cb-b40a7896886a","isSidechain":true,"agentId":"a79ab4d7e96bf8f12","message":{"model":"claude-opus-4-6","id":"msg_016q9M3eCm2H3FRpJr9P4BYW","type":"message","role":"assistant","content":[{"type":"text","text":"Good, the directory exists but is empty, and we have sympy, numpy, scipy available. Let me build the symbolic regression system."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":0,"cache_read_input_tokens":9220,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"}},"requestId":"req_011CZiLQjDKRzKE82Ezzste7","type":"assistant","uuid":"55f8b989-a10e-45b5-85a4-153269ad86fd","timestamp":"2026-04-04T07:27:42.121Z","userType":"external","entrypoint":"sdk-cli","cwd":"/apps/aplikacijos/prime-research","sessionId":"f5332890-89d2-40a2-b821-fa5bcff74ef0","version":"2.1.92","gitBranch":"HEAD","slug":"curious-jingling-sonnet"}
    {"parentUuid":"55f8b989-a10e-45b5-85a4-153269ad86fd","isSidechain":true,"agentId":"a79ab4d7e96bf8f12","message":{"model":"claude-opus-4-6","id":"msg_016q9M3eCm2H3FRpJr9P4BYW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FWNRckHyVb4p6LEGbN1wE5","name":"Write","input":{"file_path":"/apps/aplikacijos/prime-research/session6_experiments/symbolic_regression.py","content":"#!/usr/bin/env python3\n\"\"\"\nSession 6: Symbolic Regression / Genetic Programming for prime formulas.\n\nGoal: Find a closed-form-ish formula for p(n) that generalizes.\n\nApproach:\n1. Hand-crafted symbolic regression (expression trees + evolutionary search)\n2. Building blocks: n, ln(n), ln(ln(n)), sqrt(n), 1/n, constants\n3. Train on n=1..5000, test on n=5001..10000\n4. Also try parametric family optimization (analytical + scipy.optimize)\n\"\"\"\n\nimport numpy as np\nimport time\nimport random\nimport math\nimport copy\nimport json\nfrom scipy.optimize import minimize, differential_evolution\nfrom functools import lru_cache\n\n# =============================================================================\n# Part 0: Generate ground truth primes\n# =============================================================================\n\ndef sieve_primes(limit):\n    \"\"\"Sieve of Eratosthenes\"\"\"\n    is_prime = bytearray([1]) * (limit + 1)\n    is_prime[0] = is_prime[1] = 0\n    for i in range(2, int(limit**0.5) + 1):\n        if is_prime[i]:\n            is_prime[i*i::i] = bytearray(len(is_prime[i*i::i]))\n    return [i for i in range(2, limit + 1) if is_prime[i]]\n\nprint(\"Generating primes...\")\nt0 = time.time()\n# p(10000) ~ 104729, need some headroom\nALL_PRIMES = sieve_primes(120000)\nprint(f\"  Generated {len(ALL_PRIMES)} primes in {time.time()-t0:.3f}s\")\nprint(f\"  p(1)={ALL_PRIMES[0]}, p(100)={ALL_PRIMES[99]}, p(1000)={ALL_PRIMES[999]}, p(10000)={ALL_PRIMES[9999]}\")\n\n# Arrays for vectorized operations\nN_TRAIN = 5000\nN_TEST = 5000\nN_ALL = N_TRAIN + N_TEST\n\nns_all = np.arange(1, N_ALL + 1, dtype=np.float64)\nps_all = np.array(ALL_PRIMES[:N_ALL], dtype=np.float64)\n\nns_train = ns_all[:N_TRAIN]\nps_train = ps_all[:N_TRAIN]\nns_test = ns_all[N_TRAIN:]\nps_test = ps_all[N_TRAIN:]\n\n# Precompute useful quantities\nln_n = np.log(ns_all)\nln_n[0] = 0.001  # avoid log(0) issues at n=1\nln_ln_n = np.log(np.maximum(ln_n, 0.001))\nsqrt_n = np.sqrt(ns_all)\n\n# =============================================================================\n# Part 1: Parametric family optimization\n# =============================================================================\n\ndef evaluate_formula(formula_fn, ns, ps, name=\"\"):\n    \"\"\"Evaluate a formula's accuracy\"\"\"\n    try:\n        pred = formula_fn(ns)\n        if np.any(np.isnan(pred)) or np.any(np.isinf(pred)):\n            return None\n        errors = pred - ps\n        abs_errors = np.abs(errors)\n        max_err = np.max(abs_errors)\n        mean_err = np.mean(abs_errors)\n        rmse = np.sqrt(np.mean(errors**2))\n        # What fraction are exactly correct when rounded?\n        rounded = np.round(pred)\n        exact = np.sum(rounded == ps)\n        exact_pct = 100.0 * exact / len(ps)\n        # Relative error\n        rel_err = np.mean(abs_errors / ps) * 100\n        return {\n            'name': name,\n            'max_err': max_err,\n            'mean_err': mean_err,\n            'rmse': rmse,\n            'exact_pct': exact_pct,\n            'rel_err_pct': rel_err,\n            'exact_count': int(exact),\n            'total': len(ps)\n        }\n    except Exception as e:\n        return None\n\ndef print_result(r, prefix=\"\"):\n    if r is None:\n        print(f\"{prefix}  FAILED\")\n        return\n    print(f\"{prefix}  {r['name']}\")\n    print(f\"{prefix}    Mean err: {r['mean_err']:.4f}, Max err: {r['max_err']:.2f}, RMSE: {r['rmse']:.4f}\")\n    print(f\"{prefix}    Exact (rounded): {r['exact_count']}/{r['total']} ({r['exact_pct']:.2f}%)\")\n    print(f\"{prefix}    Rel err: {r['rel_err_pct']:.6f}%\")\n\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"PART 1: PARAMETRIC FAMILY OPTIMIZATION\")\nprint(\"=\"*80)\n\n# Family 1: p(n) ~ n * (ln(n) + ln(ln(n)) + a + b/ln(n) + c/ln(n)^2 + d*ln(ln(n))/ln(n))\n# This is based on the asymptotic expansion of the nth prime\n\ndef make_cipolla_extended(params):\n    a, b, c, d, e, f = params\n    def formula(ns):\n        n = ns.copy()\n        ln1 = np.log(np.maximum(n, 1.01))\n        ln2 = np.log(np.maximum(ln1, 0.01))\n        result = n * (ln1 + ln2 + a + b * ln2 / ln1 + c / ln1 + d * ln2**2 / ln1**2 + e * ln2 / ln1**2 + f / ln1**2)\n        return result\n    return formula\n\ndef cipolla_loss(params):\n    fn = make_cipolla_extended(params)\n    pred = fn(ns_train)\n    if np.any(np.isnan(pred)) or np.any(np.isinf(pred)):\n        return 1e18\n    return np.mean((pred - ps_train)**2)\n\nprint(\"\\n--- Family 1: Extended Cipolla-type asymptotic ---\")\n# Known asymptotic: p(n) ~ n*(ln(n) + ln(ln(n)) - 1 + (ln(ln(n))-2)/ln(n) - ...)\n# Start near known values\nx0 = [-1.0, 1.0, -2.0, 0.0, 0.0, 0.0]\nbounds = [(-3, 1), (-5, 5), (-10, 10), (-10, 10), (-10, 10), (-10, 10)]\n\nprint(\"  Running differential evolution...\")\nt0 = time.time()\nresult_de = differential_evolution(cipolla_loss, bounds, seed=42, maxiter=200, tol=1e-12,\n                                    popsize=30, mutation=(0.5, 1.5), recombination=0.9)\nparams1 = result_de.x\nprint(f\"  DE done in {time.time()-t0:.2f}s, loss={result_de.fun:.2f}\")\nprint(f\"  Params: {params1}\")\n\n# Polish with Nelder-Mead\nresult_nm = minimize(cipolla_loss, params1, method='Nelder-Mead',\n                     options={'maxiter': 50000, 'xatol': 1e-15, 'fatol': 1e-15})\nparams1 = result_nm.x\nprint(f\"  After polish: loss={result_nm.fun:.2f}\")\nprint(f\"  Params: a={params1[0]:.10f}, b={params1[1]:.10f}, c={params1[2]:.10f}, d={params1[3]:.10f}, e={params1[4]:.10f}, f={params1[5]:.10f}\")\n\nfn1 = make_cipolla_extended(params1)\nr_train = evaluate_formula(fn1, ns_train, ps_train, \"Cipolla-ext (train)\")\nr_test = evaluate_formula(fn1, ns_test, ps_test, \"Cipolla-ext (test)\")\nprint_result(r_train, \"  TRAIN\")\nprint_result(r_test, \"  TEST\")\n\n\n# Family 2: Higher order - add more terms\ndef make_cipolla_v2(params):\n    a, b, c, d, e, f, g, h = params\n    def formula(ns):\n        n = ns.copy()\n        ln1 = np.log(np.maximum(n, 1.01))\n        ln2 = np.log(np.maximum(ln1, 0.01))\n        t = ln2 / ln1\n        result = n * (ln1 + ln2 + a + b*t + c/ln1 + d*t**2 + e*t/ln1 + f/ln1**2 + g*t**3 + h*t**2/ln1)\n        return result\n    return formula\n\ndef cipolla_v2_loss(params):\n    fn = make_cipolla_v2(params)\n    pred = fn(ns_train)\n    if np.any(np.isnan(pred)) or np.any(np.isinf(pred)):\n        return 1e18\n    return np.mean((pred - ps_train)**2)\n\nprint(\"\\n--- Family 2: Cipolla v2 (8 params) ---\")\nx0_v2 = list(params1) + [0.0, 0.0]\nbounds_v2 = [(-3, 1), (-5, 5), (-10, 10), (-10, 10), (-10, 10), (-10, 10), (-10, 10), (-10, 10)]\n\nt0 = time.time()\nresult_de2 = differential_evolution(cipolla_v2_loss, bounds_v2, seed=42, maxiter=300, tol=1e-12,\n                                     popsize=30, mutation=(0.5, 1.5), recombination=0.9)\nparams2 = result_de2.x\nprint(f\"  DE done in {time.time()-t0:.2f}s, loss={result_de2.fun:.2f}\")\n\nresult_nm2 = minimize(cipolla_v2_loss, params2, method='Nelder-Mead',\n                      options={'maxiter': 100000, 'xatol': 1e-15, 'fatol': 1e-15})\nparams2 = result_nm2.x\nprint(f\"  After polish: loss={result_nm2.fun:.2f}\")\n\nfn2 = make_cipolla_v2(params2)\nr_train2 = evaluate_formula(fn2, ns_train, ps_train, \"Cipolla-v2 (train)\")\nr_test2 = evaluate_formula(fn2, ns_test, ps_test, \"Cipolla-v2 (test)\")\nprint_result(r_train2, \"  TRAIN\")\nprint_result(r_test2, \"  TEST\")\n\n# Family 3: Additive correction on top of n*(ln(n)+ln(ln(n))-1)\n# p(n) ~ n*(ln(n)+ln(ln(n))) + a*n + b*n/ln(n) + c*n/ln(n)^2 + d*sqrt(n)*ln(n) + e*sqrt(n) + f\ndef make_additive(params):\n    a, b, c, d, e, f, g, h = params\n    def formula(ns):\n        n = ns.copy()\n        ln1 = np.log(np.maximum(n, 1.01))\n        ln2 = np.log(np.maximum(ln1, 0.01))\n        base = n * (ln1 + ln2)\n        corr = a*n + b*n/ln1 + c*n/ln1**2 + d*n*ln2/ln1 + e*n*ln2**2/ln1**2 + f*n*ln2/ln1**2 + g*np.sqrt(n)*ln1 + h*np.sqrt(n)\n        return base + corr\n    return formula\n\ndef additive_loss(params):\n    fn = make_additive(params)\n    pred = fn(ns_train)\n    if np.any(np.isnan(pred)) or np.any(np.isinf(pred)):\n        return 1e18\n    return np.mean((pred - ps_train)**2)\n\nprint(\"\\n--- Family 3: Additive correction (8 params) ---\")\nbounds_3 = [(-3, 1), (-10, 10), (-30, 30), (-5, 5), (-5, 5), (-20, 20), (-1, 1), (-5, 5)]\nt0 = time.time()\nresult_de3 = differential_evolution(additive_loss, bounds_3, seed=42, maxiter=300, tol=1e-12,\n                                     popsize=30, mutation=(0.5, 1.5), recombination=0.9)\nparams3 = result_de3.x\nresult_nm3 = minimize(additive_loss, params3, method='Nelder-Mead',\n                      options={'maxiter': 100000, 'xatol': 1e-15, 'fatol': 1e-15})\nparams3 = result_nm3.x\nprint(f\"  Done in {time.time()-t0:.2f}s, loss={result_nm3.fun:.2f}\")\n\nfn3 = make_additive(params3)\nr_train3 = evaluate_formula(fn3, ns_train, ps_train, \"Additive-corr (train)\")\nr_test3 = evaluate_formula(fn3, ns_test, ps_test, \"Additive-corr (test)\")\nprint_result(r_train3, \"  TRAIN\")\nprint_result(r_test3, \"  TEST\")\n\n\n# =============================================================================\n# Part 2: Genetic Programming - Expression Tree Evolution\n# =============================================================================\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"PART 2: GENETIC PROGRAMMING (Expression Tree Evolution)\")\nprint(\"=\"*80)\n\n# We evolve correction terms: p(n) = base(n) + correction(n)\n# where base(n) = n*(ln(n) + ln(ln(n)) - 1)\n# This focuses the GP on finding the correction pattern\n\nbase_train = ns_train * (np.log(ns_train) + np.log(np.log(ns_train)) - 1.0)\nresiduals_train = ps_train - base_train\n\nbase_test = ns_test * (np.log(ns_test) + np.log(np.log(ns_test)) - 1.0)\nresiduals_test = ps_test - base_test\n\n# Also prepare a better base using our best parametric fit so far\nbest_params_fn = None\nbest_params_rmse = float('inf')\nfor fn, name in [(fn1, \"cipolla-ext\"), (fn2, \"cipolla-v2\"), (fn3, \"additive\")]:\n    pred = fn(ns_train)\n    rmse = np.sqrt(np.mean((pred - ps_train)**2))\n    if rmse < best_params_rmse:\n        best_params_rmse = rmse\n        best_params_fn = fn\n        best_params_name = name\n\nprint(f\"  Best parametric: {best_params_name} (RMSE={best_params_rmse:.4f})\")\n\n# Terminal set\nTERMINALS = ['n', 'ln_n', 'ln_ln_n', 'sqrt_n', 'inv_ln_n', 'const']\n# Function set\nFUNCTIONS = {\n    'add': (2, lambda a, b: a + b),\n    'sub': (2, lambda a, b: a - b),\n    'mul': (2, lambda a, b: a * b),\n    'div': (2, lambda a, b: np.where(np.abs(b) > 0.001, a / b, a)),\n    'neg': (1, lambda a: -a),\n    'sq': (1, lambda a: a * a),\n    'sqrt_abs': (1, lambda a: np.sqrt(np.abs(a))),\n}\n\nclass Node:\n    __slots__ = ['kind', 'value', 'children']\n    def __init__(self, kind, value=None, children=None):\n        self.kind = kind  # 'func' or 'term'\n        self.value = value\n        self.children = children or []\n\n    def copy(self):\n        return Node(self.kind, self.value, [c.copy() for c in self.children])\n\n    def size(self):\n        return 1 + sum(c.size() for c in self.children)\n\n    def depth(self):\n        if not self.children:\n            return 0\n        return 1 + max(c.depth() for c in self.children)\n\n    def __str__(self):\n        if self.kind == 'term':\n            if self.value[0] == 'const':\n                return f\"{self.value[1]:.4f}\"\n            return self.value[0]\n        fname = self.value\n        args = \", \".join(str(c) for c in self.children)\n        if fname in ('add', 'sub', 'mul', 'div') and len(self.children) == 2:\n            ops = {'add': '+', 'sub': '-', 'mul': '*', 'div': '/'}\n            return f\"({self.children[0]} {ops[fname]} {self.children[1]})\"\n        if fname == 'neg':\n            return f\"(-{self.children[0]})\"\n        return f\"{fname}({args})\"\n\ndef random_terminal():\n    t = random.choice(TERMINALS)\n    if t == 'const':\n        c = random.choice([random.uniform(-5, 5), random.choice([-2, -1, -0.5, 0, 0.5, 1, 2, 3, math.pi, math.e])])\n        return Node('term', ('const', c))\n    return Node('term', (t, None))\n\ndef random_tree(max_depth, p_term=0.3):\n    if max_depth <= 0 or (max_depth <= 1 and random.random() < p_term):\n        return random_terminal()\n    fname = random.choice(list(FUNCTIONS.keys()))\n    arity = FUNCTIONS[fname][0]\n    children = [random_tree(max_depth - 1, p_term) for _ in range(arity)]\n    return Node('func', fname, children)\n\n# Precomputed arrays for evaluation (train set only for speed)\nEVAL_CACHE = {\n    'n': ns_train,\n    'ln_n': np.log(ns_train),\n    'ln_ln_n': np.log(np.log(ns_train)),\n    'sqrt_n': np.sqrt(ns_train),\n    'inv_ln_n': 1.0 / np.log(ns_train),\n}\n\nEVAL_CACHE_TEST = {\n    'n': ns_test,\n    'ln_n': np.log(ns_test),\n    'ln_ln_n': np.log(np.log(ns_test)),\n    'sqrt_n': np.sqrt(ns_test),\n    'inv_ln_n': 1.0 / np.log(ns_test),\n}\n\ndef eval_tree(node, cache):\n    if node.kind == 'term':\n        name, val = node.value\n        if name == 'const':\n            return np.full(len(cache['n']), val)\n        return cache[name].copy()\n    fname = node.value\n    arity, func = FUNCTIONS[fname]\n    child_vals = [eval_tree(c, cache) for c in node.children]\n    try:\n        result = func(*child_vals)\n        if np.any(np.isnan(result)) or np.any(np.isinf(result)):\n            return np.zeros_like(cache['n'])\n        # Clamp to prevent explosion\n        result = np.clip(result, -1e15, 1e15)\n        return result\n    except:\n        return np.zeros_like(cache['n'])\n\ndef fitness(tree, target_residuals):\n    \"\"\"Lower is better. Returns RMSE of correction term.\"\"\"\n    try:\n        pred = eval_tree(tree, EVAL_CACHE)\n        err = pred - target_residuals\n        rmse = np.sqrt(np.mean(err**2))\n        # Parsimony pressure\n        size_penalty = tree.size() * 0.1\n        return rmse + size_penalty\n    except:\n        return 1e18\n\ndef get_all_nodes(tree, path=[]):\n    \"\"\"Get list of (path, node) for all nodes\"\"\"\n    result = [(list(path), tree)]\n    for i, child in enumerate(tree.children):\n        result.extend(get_all_nodes(child, path + [i]))\n    return result\n\ndef get_node_at(tree, path):\n    node = tree\n    for idx in path:\n        node = node.children[idx]\n    return node\n\ndef set_node_at(tree, path, new_node):\n    if not path:\n        return new_node\n    tree = tree.copy()\n    parent = tree\n    for idx in path[:-1]:\n        parent = parent.children[idx]\n    parent.children[path[-1]] = new_node\n    return tree\n\ndef crossover(t1, t2):\n    \"\"\"Subtree crossover\"\"\"\n    nodes1 = get_all_nodes(t1)\n    nodes2 = get_all_nodes(t2)\n    path1, _ = random.choice(nodes1)\n    path2, node2 = random.choice(nodes2)\n    child = set_node_at(t1.copy(), path1, node2.copy())\n    if child.depth() > 8:\n        return t1.copy()\n    return child\n\ndef mutate(tree, p=0.2):\n    \"\"\"Point mutation or subtree replacement\"\"\"\n    tree = tree.copy()\n    if random.random() < 0.5:\n        # Subtree replacement\n        nodes = get_all_nodes(tree)\n        path, _ = random.choice(nodes)\n        new_sub = random_tree(max_depth=2)\n        tree = set_node_at(tree, path, new_sub)\n    else:\n        # Point mutation\n        nodes = get_all_nodes(tree)\n        path, node = random.choice(nodes)\n        if node.kind == 'term':\n            new_node = random_terminal()\n        else:\n            # Change function (keeping arity compatible if possible)\n            old_arity = FUNCTIONS[node.value][0]\n            candidates = [f for f, (a, _) in FUNCTIONS.items() if a == old_arity]\n            if candidates:\n                new_node = Node('func', random.choice(candidates), [c.copy() for c in node.children])\n            else:\n                new_node = node.copy()\n        tree = set_node_at(tree, path, new_node)\n    if tree.depth() > 8:\n        return random_tree(3)\n    return tree\n\ndef tournament_select(population, fitnesses, k=5):\n    indices = random.sample(range(len(population)), min(k, len(population)))\n    best_idx = min(indices, key=lambda i: fitnesses[i])\n    return population[best_idx]\n\ndef run_gp(target_residuals, pop_size=500, generations=100, label=\"\"):\n    \"\"\"Run genetic programming evolution\"\"\"\n    print(f\"\\n  GP Run: {label}\")\n    print(f\"    Pop={pop_size}, Gen={generations}\")\n\n    # Initialize population\n    population = [random_tree(max_depth=random.randint(2, 5)) for _ in range(pop_size)]\n\n    best_ever = None\n    best_ever_fit = float('inf')\n    stagnation = 0\n\n    t0 = time.time()\n\n    for gen in range(generations):\n        # Evaluate fitness\n        fitnesses = [fitness(t, target_residuals) for t in population]\n\n        # Track best\n        gen_best_idx = min(range(len(fitnesses)), key=lambda i: fitnesses[i])\n        gen_best_fit = fitnesses[gen_best_idx]\n\n        if gen_best_fit < best_ever_fit:\n            best_ever_fit = gen_best_fit\n            best_ever = population[gen_best_idx].copy()\n            stagnation = 0\n
