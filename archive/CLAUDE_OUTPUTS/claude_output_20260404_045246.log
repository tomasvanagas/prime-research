import numpy as np
from sympy import primerange

# Get primes
primes = list(primerange(2, 250000))

# Approach: Learn delta(n) = p(n) - R_inv(n)
from mpmath import mp, mpf, li as mpli, log as mplog
mp.dps = 20

def R_inv_approx(n):
    '''Quick R^{-1} via Newton on R(x)=n'''
    from sympy import mobius
    x = float(n * np.log(n))
    for _ in range(20):
        rx = sum(int(mobius(k))/k * float(mpli(mpf(x)**(1.0/k))) for k in range(1,15) if int(mobius(k)) != 0 and x**(1.0/k) > 1.01)
        if abs(rx - n) < 0.001:
            break
        # Derivative of R at x is approximately 1/ln(x)
        x += (n - rx) * np.log(x)
    return x

# Compute deltas for small n
print('Computing deltas...')
deltas = []
for i in range(1, 501):
    r_inv = R_inv_approx(i)
    delta = primes[i-1] - round(r_inv)
    deltas.append(delta)

