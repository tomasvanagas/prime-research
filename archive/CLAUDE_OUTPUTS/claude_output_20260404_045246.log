import numpy as np
from sympy import primerange, nextprime

primes = list(primerange(2, 200000))
print(f'Got {len(primes)} primes')

# Compute delta(n) = p(n) - approx(n) where approx = n*ln(n) + n*ln(ln(n)) - n
deltas = []
for i in range(1, 10001):
    n = float(i)
    approx = n * np.log(n) + n * np.log(np.log(n + 1)) - n if i > 1 else 2
    delta = primes[i-1] - approx
    deltas.append(delta)

deltas = np.array(deltas, dtype=float)
print(f'Delta stats: mean={np.mean(deltas):.2f}, std={np.std(deltas):.2f}')
print(f'Delta range: [{min(deltas):.1f}, {max(deltas):.1f}]')

# Autocorrelation
autocorr = np.correlate(deltas - np.mean(deltas), deltas - np.mean(deltas), 'full')
autocorr = autocorr[len(autocorr)//2:]
autocorr /= autocorr[0]
print(f'Autocorrelation: r(1)={autocorr[1]:.4f}, r(5)={autocorr[5]:.4f}, r(10)={autocorr[10]:.4f}')

# Feature engineering with zeta zeros
