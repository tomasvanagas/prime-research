features = np.column_stack([
    np.log(n_vals + 1),
    np.log(np.log(n_vals + 2)),
    np.sqrt(n_vals),
    1/np.log(n_vals + 1),
    *[np.sin(g * np.log(n_vals + 1)) for g in gamma],
    *[np.cos(g * np.log(n_vals + 1)) for g in gamma],
])

