    # Residual after removing top 2
    M_approx2 = U[:,:2] @ np.diag(S[:2]) @ Vt[:2,:]
    residual = M - M_approx2
    max_err = np.max(np.abs(residual))
    mean_err = np.mean(np.abs(residual))
