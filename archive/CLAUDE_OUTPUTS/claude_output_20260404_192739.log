import numpy as np
from itertools import combinations
import time

def simple_sieve(limit):
    if limit < 2: return [False]*(limit+1)
    sieve = [True]*(limit+1)
    sieve[0] = sieve[1] = False
    for i in range(2, int(limit**0.5)+1):
        if sieve[i]:
            for j in range(i*i, limit+1, i): sieve[j] = False
    return sieve

PI_TABLE = [0]*4097
count = 0
sv = simple_sieve(4096)
for i in range(4097):
    if sv[i]: count += 1
    PI_TABLE[i] = count

def primepi(x): return PI_TABLE[min(x, 4096)] if x >= 0 else 0

def compute_pi_poly(N):
    evals = {}
    for mask in range(1 << N):
        x = sum(((mask >> i) & 1) * (1 << i) for i in range(N))
        evals[mask] = primepi(x)
    coeffs = {}
    for S_mask in range(1 << N):
        coeff = 0
        T_mask = S_mask
        while True:
            sign = (-1) ** bin(S_mask ^ T_mask).count('1')
            coeff += sign * evals[T_mask]
            if T_mask == 0: break
            T_mask = (T_mask - 1) & S_mask
        if coeff != 0:
            coeffs[frozenset(i for i in range(N) if S_mask & (1 << i))] = coeff
    return coeffs, evals

def substitution_rank(coeffs, N):
    half = N // 2
    best_rank = 0
    for A in combinations(range(N), half):
        A_set = set(A)
        B = [i for i in range(N) if i not in A_set]
        rows = 1 << len(A)
        cols = 1 << len(B)
        M = np.zeros((rows, cols))
        for S, c in coeffs.items():
            S_A = S & A_set
            S_B = S - A_set
            row = sum(1 << list(A).index(i) for i in S_A)
            col = sum(1 << B.index(i) for i in S_B)
            M[row, col] += c
        r = np.linalg.matrix_rank(M, tol=1e-10)
        if r > best_rank:
            best_rank = r
    return best_rank

for N in range(2, 9):
    t0 = time.time()
    coeffs, evals = compute_pi_poly(N)
    n_terms = len(coeffs)
    total = 1 << N
    degree = max((len(S) for S in coeffs), default=0)
    max_coeff = max(abs(c) for c in coeffs.values()) if coeffs else 0
    sparsity = 100*n_terms/total
    
    sr = substitution_rank(coeffs, N)
    t1 = time.time()
    
    print(f'N={N}: terms={n_terms}/{total} ({sparsity:.1f}%), deg={degree}, '
          f'max|c|={max_coeff}, sub_rank={sr}, lower_bound>={max(sr,2)}, time={t1-t0:.1f}s')
