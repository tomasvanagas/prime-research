import numpy as np
from itertools import combinations
import time

def simple_sieve(limit):
    if limit < 2: return [False]*(limit+1)
    sieve = [True]*(limit+1)
    sieve[0] = sieve[1] = False
    for i in range(2, int(limit**0.5)+1):
        if sieve[i]:
            for j in range(i*i, limit+1, i): sieve[j] = False
    return sieve

PI_TABLE = [0]*(65537)
count = 0
sv = simple_sieve(65536)
for i in range(65537):
    if sv[i]: count += 1
    PI_TABLE[i] = count

def primepi(x): return PI_TABLE[min(x, 65536)] if x >= 0 else 0

def compute_substitution_matrix(N):
    \"\"\"Compute the substitution matrix for balanced partition and return its rank.\"\"\"
    half = N // 2
    A = list(range(half))
    B = list(range(half, N))
    
    rows = 1 << len(A)
    cols = 1 << len(B)
    M = np.zeros((rows, cols))
    
    for r in range(rows):
        for c in range(cols):
            # Construct the full input
            x = 0
            for i, a in enumerate(A):
                if r & (1 << i): x += (1 << a)
            for i, b in enumerate(B):
                if c & (1 << i): x += (1 << b)
            M[r, c] = primepi(x)
    
    rank = np.linalg.matrix_rank(M, tol=1e-10)
    return rank, rows, cols

print('Substitution rank of pi(x) for balanced bit partition:')
print(f'{\"N\":>3} {\"rank\":>6} {\"rows\":>6} {\"cols\":>6} {\"full?\":>6} {\"2^(N/2)\":>8} {\"time\":>8}')
for N in range(2, 17):
