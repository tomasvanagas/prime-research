Now let me explore one more direction before wrapping up: a deeper investigation into what the exact rank formula **means** structurally. The fact that rank(pi_N) = 2^{N/2-1} + 2 is an exact formula, not just "approximately half," suggests underlying structure.
  [Bash] python3 -c "
import numpy as np
import time

# Build sieve
MAX = 2**20
sieve = [True]*(MAX+1)
sieve[0] = sieve[1] = False
for i in range(2, int(MAX**0.5)+1):
    if sieve[i]:
        for j in range(i*i, MAX+1, i): sieve[j] = False
pi_table = [0]*(MAX+1)
c = 0
for i in range(MAX+1):
    if sieve[i]: c += 1
    pi_table[i] = c

print('INVESTIGATING THE +2 IN rank = 2^{N/2-1} + 2')
print('='*60)

# For the balanced partition (low bits vs high bits):
# x = b + a*2^{N/2} where a = high bits (rows), b = low bits (cols)
# M[a,b] = pi(b + a*2^{N/2})
#
# rank(M) = 2^{N/2-1} + 2
#
# The +2 suggests: M can be decomposed as a rank-2 part + something
# Let's look at the SVD

for N in [8, 10, 12]:
    half = N // 2
    rows = 1 << half
    cols = 1 << (N - half)
    M = np.zeros((rows, cols))
    for a in range(rows):
        for b in range(cols):
            x = b + a * (1 << half)
            M[a, b] = pi_table[x]
    
    U, S, Vt = np.linalg.svd(M, full_matrices=False)
    
    print(f'\nN={N}: rank={int(np.sum(S > 1e-10))}, dims={rows}x{cols}')
    print(f'  Top 10 singular values: {S[:10].round(2)}')
    print(f'  Ratio S[0]/S[1]: {S[0]/S[1]:.2f}')
    print(f'  Ratio S[1]/S[2]: {S[1]/S[2]:.2f}')
    
    # The dominant singular value corresponds to the smooth part of pi(x)
    # pi(b + a*2^{N/2}) ≈ a*2^{N/2}/ln(a*2^{N/2}) + b/ln(b + a*2^{N/2})
    # This is approximately rank-1 or rank-2 in (a,b)
    
