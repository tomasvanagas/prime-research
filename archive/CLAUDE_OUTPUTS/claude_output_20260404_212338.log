    resid = gd_rank(T, rank, n_restarts=8, max_iter=2000, lr=0.004)
    elapsed = time.time() - t0
    exact = 'EXACT' if resid < 1e-4 else ''
    print(f'Rank {rank:3d}: resid={resid:.6e}  ({elapsed:.1f}s)  {exact}')
    if resid < 1e-4:
        print(f'==> TENSOR RANK (R) <= {rank}')
        break

# One random comparison
print()
rng = np.random.default_rng(999)
T_rand = (rng.random((16,16,16)) < nprimes/4096).astype(float)
