import numpy as np
from sympy import isprime
import time

np.random.seed(42)

def build_prime_tensor(N):
    k = N // 3
    d = 2 ** k
    T = np.zeros((d, d, d), dtype=np.float64)
    count = 0
    for a in range(d):
        for b in range(d):
            for c in range(d):
                x = a + b * d + c * (d * d)
                if isprime(x):
                    T[a, b, c] = 1.0
                    count += 1
    return T, count

def reconstruct(A, B, C):
    return np.einsum('ir,jr,kr->ijk', A, B, C)

def gd_rank(T, rank, n_restarts=10, max_iter=2000, lr=0.005):
    d = T.shape[0]
    best_resid = float('inf')
    for restart in range(n_restarts):
        rng = np.random.default_rng(restart * 7 + 13)
        A = rng.standard_normal((d, rank)) * 0.2
        B = rng.standard_normal((d, rank)) * 0.2
        C = rng.standard_normal((d, rank)) * 0.2
        mA, mB, mC = np.zeros_like(A), np.zeros_like(B), np.zeros_like(C)
        vA, vB, vC = np.zeros_like(A), np.zeros_like(B), np.zeros_like(C)
        for it in range(max_iter):
            approx = reconstruct(A, B, C)
            resid = approx - T
            loss = np.sum(resid**2)
            if loss < 1e-14:
                return np.sqrt(loss)
            gA = np.einsum('ijk,jr,kr->ir', resid, B, C) * 2
            gB = np.einsum('ijk,ir,kr->jr', resid, A, C) * 2
            gC = np.einsum('ijk,ir,jr->kr', resid, A, B) * 2
            t = it + 1
            for p, g, m, v in [(A,gA,mA,vA),(B,gB,mB,vB),(C,gC,mC,vC)]:
                m[:] = 0.9*m + 0.1*g
                v[:] = 0.999*v + 0.001*g**2
                mh = m / (1 - 0.9**t)
                vh = v / (1 - 0.999**t)
                p -= lr * mh / (np.sqrt(vh) + 1e-8)
        final = np.sqrt(np.sum((reconstruct(A,B,C)-T)**2))
        best_resid = min(best_resid, final)
    return best_resid

print('=== N=12 (16x16x16) ===')
T, nprimes = build_prime_tensor(12)
print(f'Primes: {nprimes}/4096 (density={nprimes/4096:.4f})')

for mode, perm in enumerate([(0,1,2),(1,0,2),(2,0,1)]):
    M = T.transpose(perm).reshape(16, 256)
    r = np.linalg.matrix_rank(M)
    print(f'Mode-{mode+1} unfolding rank (R): {r}')

# Search from unfolding rank up
# Generic 16x16x16 rank ~ 256/3 ~ 85
# But our tensor is sparse, so actual rank should be lower
print()
# Start from 14 and search upward, with fewer restarts due to cost
for rank in [14, 20, 25, 30, 35, 40, 50, 60, 70, 80]:
