        pp1 = prevprime(x_int)
        # Choose closer
        guess = np1 if abs(np1 - x_int) < abs(pp1 - x_int) else pp1
    
    error = guess - p
    errors.append(abs(error))
    if guess == p:
        correct += 1
    total += 1

print(f"Correct: {correct}/{total} = {correct/total*100:.1f}%")
print(f"Mean |error|: {np.mean(errors):.1f}")
print(f"Median |error|: {np.median(errors):.1f}")
print(f"Max |error|: {np.max(errors):.1f}")
print(f"Within ±0: {sum(1 for e in errors if e == 0)}/{total}")
print(f"Within ±10: {sum(1 for e in errors if e <= 10)}/{total}")
print(f"Within ±50: {sum(1 for e in errors if e <= 50)}/{total}")

