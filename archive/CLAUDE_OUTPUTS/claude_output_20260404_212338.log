    # Predicted oscillatory correction
    S_pred = predict_S(x_est, coeffs, gammas)
    
    # Corrected estimate: we want pi(x) = n, so x such that R(x) + S(x) = n
    # x ≈ R^{-1}(n - S(x_est))
    x_corrected = mpf(n - S_pred) * log(mpf(n - S_pred))
    for _ in range(30):
