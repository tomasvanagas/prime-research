"""
PROPOSAL 5: Recursive Delta Interpolation via Structured Points

IDEA: If delta(n) = p(n) - R^{-1}(n) has any algebraic or analytic structure,
we should be able to interpolate it from values at carefully chosen points.

Consider: delta(n) is determined by the oscillatory part of pi(x), which 
depends on the Riemann zeros. The key formula:
  pi(x) = R(x) - sum_rho R(x^rho)
  
The sum over zeros has the form:
  S(x) = sum_k c_k * x^{rho_k}  (roughly)

where rho_k = 1/2 + i*gamma_k.

INSIGHT: x^{rho_k} = x^{1/2} * e^{i*gamma_k*log(x)}
So S(x) as a function of log(x) is a TRIGONOMETRIC POLYNOMIAL:
  S(x) = x^{1/2} * sum_k c_k * e^{i*gamma_k*t}   where t = log(x)

If we sample S at 2K+1 strategic points in t-space, we can reconstruct 
the first K Fourier coefficients, giving us K zeros' contribution exactly!

THE RECURSIVE STRUCTURE:
1. Sample pi(x_j) at 2K+1 points x_j = exp(t_j) using Meissel-Lehmer (cost O(x^{2/3} per point))
2. Extract the Fourier coefficients (the zero contributions)
3. Use these to predict delta(n) at ANY point

Total cost: O(K * x^{2/3}) for preprocessing, O(polylog) per query after that.

BUT: this is a PREPROCESSING approach. If K zeros suffice for the interval
of interest, this gives O(polylog) AMORTIZED per query.

ALTERNATIVE: Can we sample at points where pi(x) is CHEAP to compute?
- pi(2^k) can be precomputed
- pi(primorial(k)) might have special structure
"""

import numpy as np
from sympy import prime, primepi, isprime, mobius
from mpmath import mp, mpf, log, li, im, re, zetazero, pi as mpi, exp, sqrt
import time

mp.dps = 30

# Get zeta zeros
print("Loading zeta zeros...")
K = 30  # number of zeros to use
gammas = [float(im(zetazero(k))) for k in range(1, K+1)]

def oscillatory_part(x, pi_x=None, R_terms=20):
    """Compute S(x) = pi(x) - R(x), the oscillatory correction"""
    x_mp = mpf(x)
    
    # Compute R(x)
    R_x = mpf(0)
    for k in range(1, R_terms + 1):
        mu_k = mobius(k)
        if mu_k != 0:
            R_x += mpf(mu_k) / k * li(x_mp ** (mpf(1)/k))
    
    if pi_x is None:
        pi_x = primepi(int(x))
    
    return float(pi_x) - float(R_x)

def fourier_analysis_of_S(x_values, S_values, gammas):
    """
    Given S(x_j) at sample points, extract the Fourier coefficients
    corresponding to each zeta zero gamma_k.
    
    Model: S(x) ≈ sum_k (a_k * cos(gamma_k * log x) + b_k * sin(gamma_k * log x)) / sqrt(x)
    """
    t_values = np.log(x_values)  # t = log(x)
    sqrt_x = np.sqrt(x_values)
    
    # Normalized S: S(x) * sqrt(x) should be a trig polynomial in log(x)
    S_normalized = np.array(S_values) * sqrt_x
    
    # Build design matrix
    n_samples = len(x_values)
    n_params = 2 * len(gammas) + 1  # cos, sin for each zero + constant
    
    A = np.zeros((n_samples, n_params))
    A[:, 0] = 1.0  # constant
    for k, g in enumerate(gammas):
        A[:, 2*k+1] = np.cos(g * t_values)
        A[:, 2*k+2] = np.sin(g * t_values)
    
    # Solve via least squares
    coeffs, residuals, rank, sv = np.linalg.lstsq(A, S_normalized, rcond=None)
    
    return coeffs

def predict_S(x, coeffs, gammas):
    """Predict S(x) from Fourier coefficients"""
    t = np.log(x)
    sx = np.sqrt(x)
    
    S_norm = coeffs[0]
    for k, g in enumerate(gammas):
        S_norm += coeffs[2*k+1] * np.cos(g * t)
        S_norm += coeffs[2*k+2] * np.sin(g * t)
    
    return S_norm / sx

print("=" * 70)
print("PROPOSAL 5: Recursive Delta Interpolation")
print("=" * 70)

# Step 1: Sample S(x) at strategic points
print("\n--- Step 1: Sample oscillatory part S(x) at training points ---")
train_x = np.exp(np.linspace(np.log(100), np.log(8000), 200))
train_x = np.unique(np.round(train_x).astype(int))

t0 = time.time()
train_S = []
for x in train_x:
    s = oscillatory_part(int(x))
    train_S.append(s)
train_S = np.array(train_S)
t1 = time.time()
print(f"Computed {len(train_x)} sample points in {t1-t0:.1f}s")

# Step 2: Fourier decomposition
print("\n--- Step 2: Fourier decomposition ---")
for n_zeros_use in [5, 10, 15, 20, 30]:
    coeffs = fourier_analysis_of_S(train_x.astype(float), train_S, gammas[:n_zeros_use])
    
    # Test on training data
    train_pred = np.array([predict_S(x, coeffs, gammas[:n_zeros_use]) for x in train_x])
    train_rmse = np.sqrt(np.mean((train_S - train_pred)**2))
    
    # Test on held-out points
    test_x = np.arange(8500, 10000, 10)
    test_S = np.array([oscillatory_part(int(x)) for x in test_x])
    test_pred = np.array([predict_S(x, coeffs, gammas[:n_zeros_use]) for x in test_x])
    test_rmse = np.sqrt(np.mean((test_S - test_pred)**2))
    
    print(f"  {n_zeros_use:>2} zeros: train_RMSE={train_rmse:.3f}, test_RMSE={test_rmse:.3f}")

# Step 3: Can we use this to predict p(n)?
print("\n--- Step 3: Predicting p(n) from interpolated S(x) ---")
coeffs = fourier_analysis_of_S(train_x.astype(float), train_S, gammas)

correct = 0
total = 0
errors = []

for n in range(100, 1001):
    p = prime(n)
    
    # Predict pi(x) = R(x) + S_predicted(x)
    # We want x such that pi(x) transitions at n
    # Use R^{-1}(n) as starting point, then correct with S
    
    x_mp = mpf(n) * log(mpf(n))
    for _ in range(30):
        rx = li(x_mp)
        dx = 1 / log(x_mp)
        x_mp += (mpf(n) - rx) / dx
