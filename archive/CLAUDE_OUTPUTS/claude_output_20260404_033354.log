    {"parentUuid":"2cc2d625-6efe-4b5c-82ff-0f5ca8198018","isSidechain":true,"agentId":"ac1fad1b359199be3","message":{"model":"claude-opus-4-6","id":"msg_01HyxZXA4pLT9d1j9GDdJepk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NaZWeDJmC1UpAk4NQY6pNP","name":"Write","input":{"file_path":"/apps/aplikacijos/prime-research/session4_experiments/correction_analysis.py","content":"#!/usr/bin/env python3\n\"\"\"\nSession 4: Fine-structure analysis of delta(n) = p(n) - round(R_inv(n))\n=========================================================================\nInvestigates whether delta(n) has exploitable structure beyond random-walk behavior.\n\"\"\"\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom matplotlib.gridspec import GridSpec\nfrom scipy import signal, stats\nfrom scipy.ndimage import uniform_filter1d\nimport os, sys, time\n\nOUTDIR = os.path.dirname(os.path.abspath(__file__))\nN_MAX = 100_000\n\n# ============================================================\n# 1. Compute primes and R_inv\n# ============================================================\n\ndef compute_primes(n_max):\n    \"\"\"Use sympy to get first n_max primes.\"\"\"\n    from sympy import primerange, prime\n    # Get an upper bound for the n_max-th prime\n    # p(n) ~ n*(ln(n) + ln(ln(n))) for large n\n    import math\n    if n_max < 6:\n        ub = 15\n    else:\n        ln = math.log(n_max)\n        lnln = math.log(ln)\n        ub = int(n_max * (ln + lnln + 2)) + 100\n    primes = np.array(list(primerange(2, ub + 1)), dtype=np.int64)\n    return primes[:n_max]\n\ndef R_function(x, terms=200):\n    \"\"\"Riemann R(x) = sum_{k=1}^{terms} mu(k)/k * li(x^{1/k})\"\"\"\n    from mpmath import mp, mpf, li, moebius, log, power\n    mp.dps = 30\n    x = mpf(x)\n    if x <= 1:\n        return mpf(0)\n    s = mpf(0)\n    for k in range(1, terms + 1):\n        mu_k = moebius(k)\n        if mu_k == 0:\n            continue\n        xk = power(x, mpf(1) / k)\n        if xk > 1:\n            s += mpf(mu_k) / k * li(xk)\n    return s\n\ndef R_inv_approx(n, tol=0.5):\n    \"\"\"Approximate R^{-1}(n) via Newton's method on R(x) = n.\"\"\"\n    from mpmath import mp, mpf, log, pi\n    mp.dps = 30\n    n_mp = mpf(n)\n    # Initial guess: n * log(n)\n    if n < 5:\n        x = mpf(n * 3)\n    else:\n        x = n_mp * float(np.log(n))\n\n    for _ in range(100):\n        rx = R_function(x)\n        err = rx - n_mp\n        if abs(err) < tol:\n            break\n        # R'(x) ~ 1/log(x)\n        deriv = 1.0 / float(log(x))\n        x = x - err / deriv\n        if x < 2:\n            x = mpf(2)\n    return float(x)\n\ndef compute_R_inv_batch(indices):\n    \"\"\"Compute R_inv for a batch of indices. Uses vectorized initial guess.\"\"\"\n    from mpmath import mp, mpf\n    mp.dps = 30\n    results = np.zeros(len(indices), dtype=np.float64)\n    for i, n in enumerate(indices):\n        results[i] = R_inv_approx(n)\n        if (i + 1) % 5000 == 0:\n            print(f\"  R_inv: {i+1}/{len(indices)} done\")\n    return results\n\nprint(\"=\" * 70)\nprint(\"SESSION 4: FINE STRUCTURE OF delta(n) = p(n) - round(R_inv(n))\")\nprint(\"=\" * 70)\n\n# Step 1: Get primes\nprint(f\"\\n[1] Computing first {N_MAX} primes...\")\nt0 = time.time()\nprimes = compute_primes(N_MAX)\nprint(f\"    Done in {time.time()-t0:.1f}s. p({N_MAX}) = {primes[-1]}\")\n\n# Step 2: Compute R_inv for all n\n# For speed, we'll compute R_inv for a subset and interpolate,\n# then compute exactly for analysis points\n# Actually, computing 100k R_inv values with mpmath is slow.\n# Let's use a fast approximation: li_inv via scipy + correction\n\ndef fast_R_inv(n_array):\n    \"\"\"Fast vectorized R_inv approximation.\n    R(x) ~ li(x) - li(sqrt(x))/2 - li(x^{1/3})/3 + ...\n    We invert R(x) = n by first inverting li(x) = n, then correcting.\n    \"\"\"\n    from scipy.special import expi\n    from scipy.optimize import brentq\n    import math\n\n    results = np.zeros(len(n_array), dtype=np.float64)\n\n    for i, n in enumerate(n_array):\n        if n <= 1:\n            results[i] = 2.0\n            continue\n\n        # Initial guess from li_inv: li(x) = n => x ~ n*ln(n)\n        ln_n = math.log(n)\n        x0 = n * ln_n\n        if n > 5:\n            x0 = n * (ln_n + math.log(ln_n) - 1)\n\n        # Newton iterations for R(x) = n using a fast R(x) with few terms\n        x = x0\n        for _ in range(50):\n            # R(x) with first few Mobius terms\n            lx = math.log(x)\n            li_x = expi(lx)  # li(x) ~ Ei(ln(x))\n            sqx = math.sqrt(x)\n            li_sq = expi(math.log(sqx)) if sqx > 1 else 0\n            cbx = x ** (1.0/3)\n            li_cb = expi(math.log(cbx)) if cbx > 1 else 0\n            x5 = x ** 0.2\n            li_5 = expi(math.log(x5)) if x5 > 1 else 0\n\n            rx = li_x - 0.5 * li_sq - (1.0/3) * li_cb - (1.0/5) * li_5\n            # Add mu(6)/6 = 1/6 term\n            x6 = x ** (1.0/6)\n            if x6 > 1:\n                rx += (1.0/6) * expi(math.log(x6))\n\n            err = rx - n\n            deriv = 1.0 / lx  # R'(x) ~ 1/log(x)\n            dx = err / deriv\n            x = x - dx\n            if x < 2:\n                x = 2.0\n            if abs(dx) < 0.01:\n                break\n\n        results[i] = x\n\n        if (i + 1) % 10000 == 0:\n            print(f\"  R_inv: {i+1}/{len(n_array)}\")\n\n    return results\n\nprint(f\"\\n[2] Computing R_inv(n) for n=1..{N_MAX}...\")\nt0 = time.time()\nn_array = np.arange(1, N_MAX + 1, dtype=np.float64)\nR_inv = fast_R_inv(n_array)\nprint(f\"    Done in {time.time()-t0:.1f}s\")\n\n# delta(n) = p(n) - round(R_inv(n))\ndelta = primes.astype(np.float64) - np.round(R_inv)\nprint(f\"\\n    delta statistics:\")\nprint(f\"    mean = {np.mean(delta):.3f}\")\nprint(f\"    std  = {np.std(delta):.3f}\")\nprint(f\"    min  = {np.min(delta):.0f}, max = {np.max(delta):.0f}\")\n\n# ============================================================\n# 2. Modular biases in delta(n)\n# ============================================================\nprint(f\"\\n[3] Modular analysis of delta(n)...\")\n\nfig, axes = plt.subplots(2, 4, figsize=(20, 10))\nmoduli = [2, 3, 4, 5, 6, 10, 12, 30]\n\nmod_results = {}\nfor idx, m in enumerate(moduli):\n    ax = axes[idx // 4, idx % 4]\n    residues = delta.astype(int) % m\n    counts = np.bincount(residues, minlength=m)\n    expected = len(delta) / m\n    chi2 = np.sum((counts - expected)**2 / expected)\n    p_val = 1 - stats.chi2.cdf(chi2, m - 1)\n    mod_results[m] = {'counts': counts, 'chi2': chi2, 'p_val': p_val}\n\n    ax.bar(range(m), counts / len(delta), color='steelblue', alpha=0.7)\n    ax.axhline(y=1.0/m, color='red', linestyle='--', alpha=0.5)\n    ax.set_title(f'delta mod {m}\\nchi2={chi2:.1f}, p={p_val:.4f}')\n    ax.set_xlabel('Residue')\n    ax.set_ylabel('Frequency')\n    print(f\"    mod {m:2d}: chi2 = {chi2:10.1f}, p-value = {p_val:.6f}  {'*** SIGNIFICANT ***' if p_val < 0.001 else ''}\")\n\nplt.tight_layout()\nplt.savefig(os.path.join(OUTDIR, 'modular_biases.png'), dpi=150)\nplt.close()\n\n# ============================================================\n# 3. Relation to prime gaps\n# ============================================================\nprint(f\"\\n[4] Relation between delta(n) and prime gaps...\")\n\ngaps = np.diff(primes).astype(np.float64)\n# Expected gap ~ log(p(n))\nexpected_gaps = np.log(primes[:-1].astype(np.float64))\ngap_deviation = gaps - expected_gaps  # How much gap exceeds expectation\ncumulative_gap_dev = np.cumsum(gap_deviation)\n\nfig, axes = plt.subplots(2, 2, figsize=(16, 12))\n\n# Panel 1: delta vs cumulative gap deviation\nax = axes[0, 0]\nax.plot(cumulative_gap_dev[:10000], alpha=0.5, label='cumul gap deviation', linewidth=0.5)\nax.plot(delta[:10000], alpha=0.5, label='delta(n)', linewidth=0.5)\nax.set_title('delta(n) vs cumulative gap deviation (first 10k)')\nax.legend()\nax.set_xlabel('n')\n\n# Correlation\ncorr_gd = np.corrcoef(delta[:-1], cumulative_gap_dev)[0, 1]\nprint(f\"    Correlation(delta, cumul_gap_dev) = {corr_gd:.6f}\")\n\n# Panel 2: scatter delta vs local gap\nax = axes[0, 1]\nax.scatter(gaps[:10000], delta[1:10001], alpha=0.05, s=1)\nax.set_xlabel('gap g(n)')\nax.set_ylabel('delta(n+1)')\nax.set_title('delta(n+1) vs gap g(n)')\n\ncorr_dg = np.corrcoef(gaps[:N_MAX-1], delta[1:])[0, 1]\nprint(f\"    Correlation(delta(n+1), gap(n)) = {corr_dg:.6f}\")\n\n# Panel 3: delta differences vs gaps\ndelta_diff = np.diff(delta)\nax = axes[1, 0]\n# delta(n+1) - delta(n) = p(n+1) - p(n) - (round(R_inv(n+1)) - round(R_inv(n)))\n#                        = gap(n) - (round(R_inv(n+1)) - round(R_inv(n)))\nR_inv_diff = np.diff(np.round(R_inv))\nax.hist(delta_diff, bins=200, density=True, alpha=0.7, range=(-50, 50))\nax.set_title('Distribution of delta(n+1) - delta(n)')\nax.set_xlabel('delta diff')\nax.set_ylabel('density')\nprint(f\"    delta_diff mean = {np.mean(delta_diff):.4f}, std = {np.std(delta_diff):.4f}\")\n\n# Panel 4: Autocorrelation of delta\nax = axes[1, 1]\nmax_lag = 200\nautocorr = np.correlate(delta - np.mean(delta), delta - np.mean(delta), mode='full')\nautocorr = autocorr[len(autocorr)//2:]\nautocorr = autocorr / autocorr[0]\nax.plot(range(max_lag), autocorr[:max_lag])\nax.set_title('Autocorrelation of delta(n)')\nax.set_xlabel('Lag')\nax.set_ylabel('ACF')\nax.axhline(y=0, color='gray', linestyle='--')\nprint(f\"    ACF(1) = {autocorr[1]:.6f}\")\nprint(f\"    ACF(10) = {autocorr[10]:.6f}\")\nprint(f\"    ACF(100) = {autocorr[100]:.6f}\")\n\nplt.tight_layout()\nplt.savefig(os.path.join(OUTDIR, 'gap_analysis.png'), dpi=150)\nplt.close()\n\n# ============================================================\n# 4. Chebyshev bias in delta\n# ============================================================\nprint(f\"\\n[5] Chebyshev bias: delta for primes = 1 vs 3 (mod 4)...\")\n\np_mod4 = primes % 4\nmask_1 = (p_mod4 == 1)\nmask_3 = (p_mod4 == 3)\n\ndelta_1 = delta[mask_1]\ndelta_3 = delta[mask_3]\n\nprint(f\"    Primes = 1 (mod 4): {np.sum(mask_1)} primes, mean delta = {np.mean(delta_1):.4f}, std = {np.std(delta_1):.4f}\")\nprint(f\"    Primes = 3 (mod 4): {np.sum(mask_3)} primes, mean delta = {np.mean(delta_3):.4f}, std = {np.std(delta_3):.4f}\")\n\nt_stat, t_pval = stats.ttest_ind(delta_1, delta_3)\nprint(f\"    t-test: t = {t_stat:.4f}, p = {t_pval:.6f}\")\n\n# Also check mod 3, mod 6 residue classes\nfig, axes = plt.subplots(1, 3, figsize=(18, 5))\n\nax = axes[0]\nax.hist(delta_1, bins=100, alpha=0.5, density=True, label=f'p=1(mod4), mean={np.mean(delta_1):.2f}', range=(-200, 200))\nax.hist(delta_3, bins=100, alpha=0.5, density=True, label=f'p=3(mod4), mean={np.mean(delta_3):.2f}', range=(-200, 200))\nax.legend()\nax.set_title('delta distribution by Chebyshev class (mod 4)')\n\n# Running difference of means\nax = axes[1]\nwindow = 1000\nrunning_mean_1 = np.full(N_MAX, np.nan)\nrunning_mean_3 = np.full(N_MAX, np.nan)\n# Compute running means\ncum_sum_1 = np.cumsum(delta * mask_1)\ncum_cnt_1 = np.cumsum(mask_1)\ncum_sum_3 = np.cumsum(delta * mask_3)\ncum_cnt_3 = np.cumsum(mask_3)\n\nsafe_idx = np.where((cum_cnt_1 > 0) & (cum_cnt_3 > 0))[0]\nrm1 = cum_sum_1[safe_idx] / cum_cnt_1[safe_idx]\nrm3 = cum_sum_3[safe_idx] / cum_cnt_3[safe_idx]\nax.plot(safe_idx, rm1 - rm3, linewidth=0.5)\nax.set_title('Running mean(delta|p=1 mod4) - mean(delta|p=3 mod4)')\nax.set_xlabel('n')\nax.axhline(y=0, color='red', linestyle='--')\n\n# Mod 6: primes are 1 or 5 mod 6\nax = axes[2]\np_mod6 = primes % 6\nmask_6_1 = (p_mod6 == 1)\nmask_6_5 = (p_mod6 == 5)\nd61 = delta[mask_6_1]\nd65 = delta[mask_6_5]\nax.hist(d61, bins=100, alpha=0.5, density=True, label=f'p=1(mod6), mean={np.mean(d61):.2f}', range=(-200, 200))\nax.hist(d65, bins=100, alpha=0.5, density=True, label=f'p=5(mod6), mean={np.mean(d65):.2f}', range=(-200, 200))\nax.legend()\nax.set_title('delta distribution by class (mod 6)')\nt6, p6 = stats.ttest_ind(d61, d65)\nprint(f\"    mod 6: t = {t6:.4f}, p =
