def li(x):
    if x<=1: return float('-inf')
    lnx=math.log(x); r=_EG+math.log(lnx); t=1.0
    for k in range(1,200):
        t*=lnx/k; c=t/k; r+=c
        if abs(c)<1e-15*max(1,abs(r)): break
    return r
def R(x):
    if x<=1: return 0.0
    r=0.0
    for k in range(1,len(_MU)):
        if _MU[k]==0: continue
        xk=x**(1.0/k)
        if xk<=1.001: break
        r+=_MU[k]/k*li(xk)
    return r
def R_inv(n):
    if n<=1: return 2.0
    x=float(n)*math.log(n)
    if n>5: x=float(n)*(math.log(n)+math.log(math.log(n)))
    for _ in range(100):
        x=max(x,2.0); r=R(x); err=n-r
        if abs(err)<1e-8: break
        dx=err*math.log(x); x+=dx; x=max(x,2.0)
        if abs(dx)<1e-8: break
    return x

def sieve(limit):
    s=bytearray(b'\\x01')*(limit+1); s[0]=s[1]=0
    for i in range(2,int(limit**0.5)+1):
        if s[i]: s[i*i::i]=bytearray(len(s[i*i::i]))
    return [i for i in range(2,limit+1) if s[i]]

