import math

def lucy_pi(n):
    if n < 2: return 0
    sqrtn = int(n**0.5)
    small = [0] * (sqrtn + 2)
    large = [0] * (sqrtn + 2)
    for i in range(1, sqrtn + 1):
        small[i] = i - 1
        large[i] = n // i - 1
    for p in range(2, sqrtn + 1):
        if small[p] == small[p-1]: continue
        pc = small[p-1]; p2 = p*p
        for k in range(1, min(sqrtn, n//p2)+1):
            nkp = k*p
            if nkp <= sqrtn: large[k] -= large[nkp] - pc
            else: large[k] -= small[n//nkp] - pc
        for v in range(sqrtn, p2-1, -1):
            small[v] -= small[v//p] - pc
    return large[1]

