    pi0 = lucy_pi(x0)
    
    # Newton step
    diff0 = n - pi0
    step = max(1, abs(int(round(diff0 * math.log(x0)))))
    x1 = x0 + step if diff0 > 0 else x0 - step
    pi1 = lucy_pi(x1)
    
    if pi0 == pi1:
        # Same count — can't interpolate. Just use Newton estimate
        p_est = x1
    else:
        # Secant method interpolation
        x_target = x0 + (n - pi0) * (x1 - x0) / (pi1 - pi0)
        p_est = int(round(x_target))
    
